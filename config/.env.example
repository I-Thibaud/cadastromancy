# ---------------------------------------------------------------
# Configuration de la pipeline cadastre NN / DFI
# Copier ce fichier en "config/.env" et renseigner les valeurs.
# NE JAMAIS versionner le fichier .env (ajouter config/.env au .gitignore)
# ---------------------------------------------------------------

# --- Connexion PostgreSQL ---
DB_USER=user
DB_PASSWORD=mdp
DB_HOST=host
DB_PORT=port
DB_NAME=nom_bdd
DB_SCHEMA=nom_schema

# --- Filtre géographique ---
# Département INSEE a noté sur 2 caractères (Finistère = 29).
# Le code département DFI ("290") et les codes INSEE complets ("29017", ...)
# sont dérivés automatiquement.
DEPARTEMENT=29

# Codes commune sur 3 caractères, séparés par des virgules, sans espaces
CODES_COMMUNE=017,040,076,084,098,099,109,112,119,130,177,178,190,201,208,221,260,282,299
